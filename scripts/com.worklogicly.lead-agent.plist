<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.worklogicly.lead-agent</string>

    <!-- Wrapper is staged by install-launchd.sh to ~/.worklogicly/ because
         macOS TCC degrades launchd processes whose executable lives under
         ~/Desktop. Source of truth: scripts/run-agent.sh in the repo. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/josias/.worklogicly/run-agent.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/josias/Desktop/CODE/Lead-Scraper</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/josias</string>
        <key>USER</key>
        <string>josias</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/Users/josias/Library/Logs/worklogicly-lead-agent.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/josias/Library/Logs/worklogicly-lead-agent.err.log</string>
</dict>
</plist>
